package com.example.employeesystem.service;

import com.example.employeesystem.entity.Employee;
import com.example.employeesystem.repository.EmployeeRepository;
import com.example.employeesystem.utils.XmlValidator;
import com.example.employeesystem.xmlmodel.EmployeeXml;

import jakarta.validation.Validation;
import jakarta.validation.Validator;
import jakarta.validation.ValidatorFactory;
import jakarta.validation.ConstraintViolation;

import jakarta.xml.bind.JAXBContext;
import jakarta.xml.bind.JAXBException;
import jakarta.xml.bind.Unmarshaller;

import org.springframework.stereotype.Service;

import java.io.StringReader;
import java.util.Set;

@Service
public class EmployeeXmlService {

    private final EmployeeRepository employeeRepository;
    private final JAXBContext jaxbContext;
    private final Validator validator;

    public EmployeeXmlService(EmployeeRepository employeeRepository, JAXBContext jaxbContext) {
        this.employeeRepository = employeeRepository;
        this.jaxbContext = jaxbContext;

        // Initialize Javax Validation (for @NotNull, @Email, etc)
        ValidatorFactory factory = Validation.buildDefaultValidatorFactory();
        this.validator = factory.getValidator();
    }

    // Main method to process incoming XML
    public Employee processAndSaveEmployeeXml(String xmlContent) throws Exception {
        // Step 1: Validate XML structure using XSD
        XmlValidator.validateAgainstXSD(xmlContent);

        // Step 2: Convert XML → EmployeeXml object (Unmarshal)
        Unmarshaller unmarshaller = jaxbContext.createUnmarshaller();
        EmployeeXml employeeXml = (EmployeeXml) unmarshaller.unmarshal(new StringReader(xmlContent));

        // Step 3: Perform Javax validation on fields
        validateEmployeeXml(employeeXml);

        // Step 4: Convert EmployeeXml -> Employee entity
        Employee employee = mapToEntity(employeeXml);

        // Step 5: Persist data into MySQL database
        return employeeRepository.save(employee);
    }

    // Validate constraints defined in EmployeeXml.java
    private void validateEmployeeXml(EmployeeXml employeeXml) {
        Set<ConstraintViolation<EmployeeXml>> violations = validator.validate(employeeXml);
        if (!violations.isEmpty()) {
            StringBuilder errorMsg = new StringBuilder("Validation errors: ");
            for (ConstraintViolation<EmployeeXml> violation : violations) {
                errorMsg.append(violation.getPropertyPath())
                        .append(" ")
                        .append(violation.getMessage())
                        .append("; ");
            }
            throw new RuntimeException(errorMsg.toString());
        }
    }

    // Converts the XML model into a database entity
    private Employee mapToEntity(EmployeeXml employeeXml) {
        return Employee.builder()
                .name(employeeXml.getName())
                .email(employeeXml.getEmail())
                .department(employeeXml.getDepartment())
                .dateOfJoining(employeeXml.getDateOfJoining())
                .status("ACTIVE")
                .build();
    }
}
